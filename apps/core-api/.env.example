# Copy to .env (gitignored).
# Supabase runtime (pooled): use Supavisor pooler host + port 6543.
# Keep pgbouncer=true, sslmode=require, and connection_limit=1.
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Supabase direct: use direct host + port 5432 for migrations.
DIRECT_URL="postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# HTTP port for Nest (health is at GET /health, API under /api/v1)
PORT=3000

JWT_SECRET="change-me-local-dev-only"
APP_VERSION="Beta V1.16.77"
NODE_ENV="development"
BUILD_HASH="local-supabase"

# Prisma DB connect retry policy.
# Production recommendation: fast-fail and let the process restart quickly.
# PRISMA_CONNECT_MAX_RETRIES=3
# PRISMA_CONNECT_RETRY_DELAY_MS=1000
# Local dev (optional): tolerate cold DB starts with a few extra retries.
# PRISMA_CONNECT_MAX_RETRIES=5
# PRISMA_CONNECT_RETRY_DELAY_MS=750

# Optional: GitHub Issues for bug reports (see docs/deployment.md)
# GITHUB_ISSUES_TOKEN=
# GITHUB_ISSUES_REPO=
