generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum DistributionMovementType {
  PURCHASE_RECEIPT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_INCREASE
  ADJUSTMENT_DECREASE
  DISPATCH_ISSUE
  RETURN_IN
  RETURN_OUT
  DAMAGED_WRITE_OFF
  STOCK_CORRECTION
}

enum GoodsReceiptStatus {
  DRAFT
  PARTIAL
  RECEIVED
  CLOSED
  CANCELLED
}

enum StockTransferStatus {
  DRAFT
  REQUESTED
  APPROVED
  DISPATCHED
  PARTIAL
  COMPLETED
  CANCELLED
}

enum DispatchStatus {
  DRAFT
  READY
  PACKED
  DISPATCHED
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum StockAdjustmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  APPLIED
  REVERSED
}

enum StockAdjustmentType {
  INCREASE
  DECREASE
}

enum StockReturnType {
  SUPPLIER_RETURN
  CUSTOMER_RETURN
  INTERNAL_RETURN
  TRANSFER_RETURN
}

enum StockReturnStatus {
  DRAFT
  RECEIVED
  INSPECTED
  COMPLETED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  EXPIRED
  FULFILLED
  CANCELLED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Organization {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  branches               Branch[]
  users                  User[]
  items                  Item[]
  suppliers              Supplier[]
  purchase_orders        PurchaseOrder[]
  contacts               Contact[]
  leads                  Lead[]
  opportunities          Opportunity[]
  audit_logs             AuditLog[]
  inventory_stocks       InventoryStock[]
  inventory_movements    InventoryMovement[]
  goods_receipts         GoodsReceipt[]
  stock_transfers        StockTransfer[]
  stock_adjustments      StockAdjustment[]
  stock_dispatches       StockDispatch[]
  stock_returns          StockReturn[]
  inventory_reservations InventoryReservation[]
  reorder_rules          ReorderRule[]
  stock_alerts           StockAlert[]
  warehouse_locations    WarehouseLocation[]
  inventory_lots         InventoryLot[]
  inventory_lot_balances InventoryLotBalance[]
  dispatch_pick_jobs     DispatchPickJob[]
  dispatch_pack_jobs     DispatchPackJob[]

  @@map("organizations")
}

model Branch {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime? @db.Timestamptz(6)
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid

  organization           Organization           @relation(fields: [organization_id], references: [id])
  users                  User[]
  items                  Item[]
  suppliers              Supplier[]
  purchase_orders        PurchaseOrder[]
  contacts               Contact[]
  leads                  Lead[]
  opportunities          Opportunity[]
  inventory_stocks       InventoryStock[]
  inventory_movements    InventoryMovement[]
  source_movements       InventoryMovement[]    @relation("InventoryMovementSourceBranch")
  destination_movements  InventoryMovement[]    @relation("InventoryMovementDestinationBranch")
  goods_receipts         GoodsReceipt[]
  outgoing_transfers     StockTransfer[]        @relation("StockTransferSourceBranch")
  incoming_transfers     StockTransfer[]        @relation("StockTransferDestinationBranch")
  stock_adjustments      StockAdjustment[]
  stock_dispatches       StockDispatch[]
  source_returns         StockReturn[]          @relation("StockReturnSourceBranch")
  destination_returns    StockReturn[]          @relation("StockReturnDestinationBranch")
  inventory_reservations InventoryReservation[]
  reorder_rules          ReorderRule[]
  stock_alerts           StockAlert[]
  warehouse_locations    WarehouseLocation[]
  inventory_lots         InventoryLot[]
  inventory_lot_balances InventoryLotBalance[]
  dispatch_pick_jobs     DispatchPickJob[]
  dispatch_pack_jobs     DispatchPackJob[]

  @@index([organization_id], map: "idx_branches_org")
  @@index([deleted_at], map: "idx_branches_deleted_at")
  @@index([created_at], map: "idx_branches_created_at")
  @@map("branches")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  branch_id       String?   @db.Uuid
  email           String    @unique
  password_hash   String
  status          String    @default("ACTIVE")
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime? @db.Timestamptz(6)
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid

  organization   Organization   @relation(fields: [organization_id], references: [id])
  branch         Branch?        @relation(fields: [branch_id], references: [id])
  user_roles     UserRole[]
  refresh_tokens RefreshToken[]

  @@index([organization_id], map: "idx_users_org")
  @@index([branch_id], map: "idx_users_branch")
  @@index([email, deleted_at, status], map: "idx_users_email_deleted_status")
  @@index([deleted_at], map: "idx_users_deleted_at")
  @@index([created_at], map: "idx_users_created_at")
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_refresh_tokens_user")
  @@index([expires_at], map: "idx_refresh_tokens_expires_at")
  @@index([revoked_at], map: "idx_refresh_tokens_revoked_at")
  @@map("refresh_tokens")
}

model Role {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  user_roles UserRole[]

  @@index([deleted_at], map: "idx_roles_deleted_at")
  @@index([created_at], map: "idx_roles_created_at")
  @@map("roles")
}

model UserRole {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  role_id    String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id])

  @@unique([user_id, role_id], map: "uq_user_roles_user_role")
  @@index([user_id], map: "idx_user_roles_user")
  @@index([role_id], map: "idx_user_roles_role")
  @@index([deleted_at], map: "idx_user_roles_deleted_at")
  @@map("user_roles")
}

model Item {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id  String     @db.Uuid
  branch_id        String?    @db.Uuid
  name             String
  sku              String
  description      String?    @db.Text
  status           ItemStatus @default(ACTIVE)
  cost_price       Decimal    @default(0) @db.Decimal(12, 2)
  selling_price    Decimal    @default(0) @db.Decimal(12, 2)
  currency         String     @default("USD")
  track_inventory  Boolean    @default(true)
  quantity_on_hand Int        @default(0)
  reorder_level    Int        @default(0)
  max_stock_level  Int?
  unit_of_measure  String     @default("piece")
  category_id      String?
  tags             String[]   @default([])
  brand            String?
  barcode          String?
  is_service       Boolean    @default(false)
  tax_rate         Decimal    @default(0) @db.Decimal(5, 2)
  discountable     Boolean    @default(true)
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @updatedAt @db.Timestamptz(6)
  deleted_at       DateTime?  @db.Timestamptz(6)
  created_by       String?    @db.Uuid
  updated_by       String?    @db.Uuid

  organization           Organization            @relation(fields: [organization_id], references: [id])
  branch                 Branch?                 @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  po_line_items          PurchaseOrderLineItem[]
  inventory_stocks       InventoryStock[]
  inventory_movements    InventoryMovement[]
  goods_receipt_lines    GoodsReceiptLine[]
  transfer_lines         StockTransferLine[]
  adjustment_lines       StockAdjustmentLine[]
  dispatch_lines         StockDispatchLine[]
  return_lines           StockReturnLine[]
  inventory_reservations InventoryReservation[]
  reorder_rules          ReorderRule[]
  stock_alerts           StockAlert[]
  inventory_lots         InventoryLot[]
  inventory_lot_balances InventoryLotBalance[]
  dispatch_pick_lines    DispatchPickLine[]
  dispatch_pack_lines    DispatchPackLine[]

  @@unique([organization_id, sku], map: "uq_items_org_sku")
  @@index([organization_id], map: "idx_items_org")
  @@index([branch_id], map: "idx_items_branch")
  @@index([status], map: "idx_items_status")
  @@index([category_id], map: "idx_items_category")
  @@index([deleted_at], map: "idx_items_deleted_at")
  @@index([created_at], map: "idx_items_created_at")
  @@index([organization_id, deleted_at, created_at], map: "idx_items_org_deleted_created")
  @@index([organization_id, branch_id, deleted_at, created_at], map: "idx_items_org_branch_deleted_created")
  @@map("items")
}

model Supplier {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String         @db.Uuid
  branch_id          String?        @db.Uuid
  name               String
  supplier_code      String?
  status             SupplierStatus @default(ACTIVE)
  email              String?
  phone              String?
  mobile             String?
  website            String?
  country            String?
  city               String?
  address_line_1     String?
  address_line_2     String?
  postal_code        String?
  payment_terms      String?
  currency           String         @default("USD")
  tax_id             String?
  vat_number         String?
  credit_limit       Float          @default(0)
  balance            Float          @default(0)
  contact_name       String?
  contact_email      String?
  contact_phone      String?
  notes              String?
  rating             Int?
  preferred_supplier Boolean        @default(false)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @updatedAt @db.Timestamptz(6)
  deleted_at         DateTime?      @db.Timestamptz(6)
  created_by         String?        @db.Uuid
  updated_by         String?        @db.Uuid

  organization    Organization    @relation(fields: [organization_id], references: [id])
  branch          Branch?         @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  purchase_orders PurchaseOrder[]
  goods_receipts  GoodsReceipt[]
  reorder_rules   ReorderRule[]
  inventory_lots  InventoryLot[]

  @@unique([organization_id, supplier_code], map: "uq_suppliers_org_supplier_code")
  @@index([organization_id], map: "idx_suppliers_org")
  @@index([branch_id], map: "idx_suppliers_branch")
  @@index([status], map: "idx_suppliers_status")
  @@index([deleted_at], map: "idx_suppliers_deleted_at")
  @@index([created_at], map: "idx_suppliers_created_at")
  @@index([organization_id, deleted_at, created_at], map: "idx_suppliers_org_deleted_created")
  @@map("suppliers")
}

model PurchaseOrder {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id        String              @db.Uuid
  branch_id              String?             @db.Uuid
  po_number              String              @unique
  supplier_id            String?             @db.Uuid
  status                 PurchaseOrderStatus @default(DRAFT)
  order_date             DateTime            @default(now()) @db.Timestamptz(6)
  expected_delivery_date DateTime?           @db.Timestamptz(6)
  payment_terms          String?
  subtotal               Float               @default(0)
  total_tax              Float               @default(0)
  total_discount         Float               @default(0)
  grand_total            Float               @default(0)
  payment_status         PaymentStatus       @default(UNPAID)
  notes                  String?
  shipping_address       String?
  shipping_method        String?
  tracking_number        String?
  approved_by            String?             @db.Uuid
  approved_at            DateTime?           @db.Timestamptz(6)
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @updatedAt @db.Timestamptz(6)
  deleted_at             DateTime?           @db.Timestamptz(6)
  created_by             String?             @db.Uuid
  updated_by             String?             @db.Uuid

  organization   Organization            @relation(fields: [organization_id], references: [id])
  branch         Branch?                 @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  supplier       Supplier?               @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  line_items     PurchaseOrderLineItem[]
  goods_receipts GoodsReceipt[]

  @@index([organization_id], map: "idx_purchase_orders_org")
  @@index([branch_id], map: "idx_purchase_orders_branch")
  @@index([status], map: "idx_purchase_orders_status")
  @@index([deleted_at], map: "idx_purchase_orders_deleted_at")
  @@index([created_at], map: "idx_purchase_orders_created_at")
  @@index([organization_id, branch_id, deleted_at, created_at], map: "idx_purchase_orders_org_branch_deleted_created")
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchase_order_id String   @db.Uuid
  item_id           String?  @db.Uuid
  description       String?
  quantity          Int      @default(1)
  unit_cost         Float    @default(0)
  tax_rate          Float    @default(0)
  discount          Float    @default(0)
  line_total        Float    @default(0)
  received_quantity Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  item           Item?         @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([purchase_order_id], map: "idx_po_line_items_po")
  @@index([item_id], map: "idx_po_line_items_item")
  @@map("purchase_order_line_items")
}

model Contact {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  branch_id       String?   @db.Uuid
  full_name       String
  email           String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime? @db.Timestamptz(6)
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid

  organization Organization @relation(fields: [organization_id], references: [id])
  branch       Branch?      @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  leads        Lead[]

  @@index([organization_id], map: "idx_contacts_org")
  @@index([branch_id], map: "idx_contacts_branch")
  @@index([deleted_at], map: "idx_contacts_deleted_at")
  @@index([created_at], map: "idx_contacts_created_at")
  @@index([organization_id, deleted_at, created_at], map: "idx_contacts_org_deleted_created")
  @@map("contacts")
}

model Lead {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String     @db.Uuid
  branch_id       String?    @db.Uuid
  contact_id      String?    @db.Uuid
  status          LeadStatus @default(NEW)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?  @db.Timestamptz(6)
  created_by      String?    @db.Uuid
  updated_by      String?    @db.Uuid

  organization  Organization  @relation(fields: [organization_id], references: [id])
  branch        Branch?       @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  contact       Contact?      @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  opportunities Opportunity[]

  @@index([organization_id], map: "idx_leads_org")
  @@index([branch_id], map: "idx_leads_branch")
  @@index([status], map: "idx_leads_status")
  @@index([deleted_at], map: "idx_leads_deleted_at")
  @@index([created_at], map: "idx_leads_created_at")
  @@index([organization_id, deleted_at, created_at], map: "idx_leads_org_deleted_created")
  @@map("leads")
}

model Opportunity {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String            @db.Uuid
  branch_id       String?           @db.Uuid
  lead_id         String?           @db.Uuid
  status          OpportunityStatus @default(OPEN)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  created_by      String?           @db.Uuid
  updated_by      String?           @db.Uuid

  organization Organization @relation(fields: [organization_id], references: [id])
  branch       Branch?      @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  @@index([organization_id], map: "idx_opportunities_org")
  @@index([branch_id], map: "idx_opportunities_branch")
  @@index([status], map: "idx_opportunities_status")
  @@index([deleted_at], map: "idx_opportunities_deleted_at")
  @@index([created_at], map: "idx_opportunities_created_at")
  @@index([organization_id, deleted_at, created_at], map: "idx_opportunities_org_deleted_created")
  @@map("opportunities")
}

model InventoryStock {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String    @db.Uuid
  branch_id           String    @db.Uuid
  item_id             String    @db.Uuid
  quantity_on_hand    Int       @default(0)
  reserved_quantity   Int       @default(0)
  available_quantity  Int       @default(0)
  in_transit_quantity Int       @default(0)
  incoming_quantity   Int       @default(0)
  damaged_quantity    Int       @default(0)
  stock_valuation     Decimal   @default(0) @db.Decimal(14, 2)
  last_movement_at    DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at          DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organization_id], references: [id])
  branch       Branch       @relation(fields: [branch_id], references: [id])
  item         Item         @relation(fields: [item_id], references: [id])

  @@unique([organization_id, branch_id, item_id], map: "uq_inventory_stocks_org_branch_item")
  @@index([organization_id], map: "idx_inventory_stocks_org")
  @@index([branch_id], map: "idx_inventory_stocks_branch")
  @@index([item_id], map: "idx_inventory_stocks_item")
  @@index([deleted_at], map: "idx_inventory_stocks_deleted_at")
  @@map("inventory_stocks")
}

model InventoryMovement {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String                   @db.Uuid
  branch_id             String?                  @db.Uuid
  item_id               String                   @db.Uuid
  movement_type         DistributionMovementType
  quantity              Int
  unit                  String                   @default("piece")
  source_branch_id      String?                  @db.Uuid
  destination_branch_id String?                  @db.Uuid
  source_location_id    String?                  @db.Uuid
  destination_location_id String?                @db.Uuid
  reference_type        String?
  reference_id          String?                  @db.Uuid
  status                String                   @default("POSTED")
  notes                 String?
  cost_impact           Decimal?                 @db.Decimal(12, 2)
  performed_by          String?                  @db.Uuid
  occurred_at           DateTime                 @default(now()) @db.Timestamptz(6)
  created_at            DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                 @updatedAt @db.Timestamptz(6)
  deleted_at            DateTime?                @db.Timestamptz(6)

  organization       Organization @relation(fields: [organization_id], references: [id])
  branch             Branch?      @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  item               Item         @relation(fields: [item_id], references: [id])
  source_branch      Branch?      @relation("InventoryMovementSourceBranch", fields: [source_branch_id], references: [id], onDelete: SetNull)
  destination_branch Branch?      @relation("InventoryMovementDestinationBranch", fields: [destination_branch_id], references: [id], onDelete: SetNull)
  source_location    WarehouseLocation? @relation("InventoryMovementSourceLocation", fields: [source_location_id], references: [id], onDelete: SetNull)
  destination_location WarehouseLocation? @relation("InventoryMovementDestinationLocation", fields: [destination_location_id], references: [id], onDelete: SetNull)

  @@index([organization_id], map: "idx_inventory_movements_org")
  @@index([branch_id], map: "idx_inventory_movements_branch")
  @@index([item_id], map: "idx_inventory_movements_item")
  @@index([movement_type], map: "idx_inventory_movements_type")
  @@index([occurred_at], map: "idx_inventory_movements_occurred_at")
  @@index([source_location_id], map: "idx_inventory_movements_source_location")
  @@index([destination_location_id], map: "idx_inventory_movements_destination_location")
  @@index([deleted_at], map: "idx_inventory_movements_deleted_at")
  @@map("inventory_movements")
}

model GoodsReceipt {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String             @db.Uuid
  branch_id         String             @db.Uuid
  supplier_id       String?            @db.Uuid
  purchase_order_id String?            @db.Uuid
  receiving_location_id String?        @db.Uuid
  receipt_number    String
  status            GoodsReceiptStatus @default(DRAFT)
  received_date     DateTime?          @db.Timestamptz(6)
  received_by       String?            @db.Uuid
  notes             String?
  attachments       Json?
