  deleted_at        DateTime? @db.Timestamptz(6)

  organization   Organization   @relation(fields: [organization_id], references: [id])
  branch         Branch         @relation(fields: [branch_id], references: [id])
  stock_dispatch StockDispatch  @relation(fields: [stock_dispatch_id], references: [id], onDelete: Cascade)
  lines          DispatchPackLine[]

  @@unique([organization_id, pack_number], map: "uq_dispatch_pack_jobs_org_number")
  @@index([organization_id], map: "idx_dispatch_pack_jobs_org")
  @@index([branch_id], map: "idx_dispatch_pack_jobs_branch")
  @@index([stock_dispatch_id], map: "idx_dispatch_pack_jobs_dispatch")
  @@index([deleted_at], map: "idx_dispatch_pack_jobs_deleted_at")
  @@map("dispatch_pack_jobs")
}

model DispatchPackLine {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispatch_pack_job_id  String   @db.Uuid
  stock_dispatch_line_id String  @db.Uuid
  item_id               String   @db.Uuid
  packed_qty            Int      @default(0)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @updatedAt @db.Timestamptz(6)

  dispatch_pack_job DispatchPackJob   @relation(fields: [dispatch_pack_job_id], references: [id], onDelete: Cascade)
  stock_dispatch_line StockDispatchLine @relation(fields: [stock_dispatch_line_id], references: [id], onDelete: Cascade)
  item             Item               @relation(fields: [item_id], references: [id])

  @@index([dispatch_pack_job_id], map: "idx_dispatch_pack_lines_job")
  @@index([stock_dispatch_line_id], map: "idx_dispatch_pack_lines_dispatch_line")
  @@index([item_id], map: "idx_dispatch_pack_lines_item")
  @@map("dispatch_pack_lines")
}

model StockAlert {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  branch_id       String?       @db.Uuid
  item_id         String?       @db.Uuid
  alert_type      String
  severity        AlertSeverity @default(MEDIUM)
  title           String
  message         String
  status          String        @default("OPEN")
  metadata        Json?
  detected_at     DateTime      @default(now()) @db.Timestamptz(6)
  resolved_at     DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?     @db.Timestamptz(6)

  organization Organization @relation(fields: [organization_id], references: [id])
  branch       Branch?      @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  item         Item?        @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([organization_id], map: "idx_stock_alerts_org")
  @@index([branch_id], map: "idx_stock_alerts_branch")
  @@index([item_id], map: "idx_stock_alerts_item")
  @@index([severity], map: "idx_stock_alerts_severity")
  @@index([status], map: "idx_stock_alerts_status")
  @@index([deleted_at], map: "idx_stock_alerts_deleted_at")
  @@map("stock_alerts")
}

model AuditLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?   @db.Uuid
  user_id         String?   @db.Uuid
  action          String
  entity_type     String
  entity_id       String?
  metadata        Json?
  timestamp       DateTime  @default(now()) @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime? @db.Timestamptz(6)
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid

  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)

  @@index([organization_id], map: "idx_audit_logs_org")
  @@index([user_id], map: "idx_audit_logs_user")
  @@index([created_at], map: "idx_audit_logs_created_at")
  @@index([deleted_at], map: "idx_audit_logs_deleted_at")
  @@map("audit_logs")
}
